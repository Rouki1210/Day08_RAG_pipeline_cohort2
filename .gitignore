# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables and secrets
.env
.env.*
!.env.example

# Build and packaging artifacts
build/
dist/
*.egg-info/
*.egg

# Jupyter
.ipynb_checkpoints/

# OS and editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Runtime/generated RAG artifacts
data/index/
*.log

# Large raw/generated data can be recreated by task scripts
data/landing/legal/*.pdf
data/landing/legal/*.doc
data/landing/legal/*.docx
data/landing/news/*.json
data/landing/news/*.html
data/landing/news/*.md
data/landing/news/*.txt
data/standardized/**/*.md

# Keep placeholder files if present
!data/**/.gitkeep
